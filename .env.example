# LM Studio / llama.cpp OpenAI-compatible endpoint
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio

# Chat (multimodal) model — load this in LM Studio first.
# Recommended: Google Gemma 3 4B (vision-capable, non-Chinese, fits 8GB VRAM).
LLM_MODEL=gemma-3-4b-it

# Embedding model for RAG — load this in LM Studio as well.
# Recommended: nomic-embed-text-v1.5 (non-Chinese, 768-dim).
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# --- SOP control layer (enforced in CODE, not by the prompt) ---
# Intent gate: structured pre-check that can force a clarifying question and stop
# the turn before any answer is generated.
SOP_INTENT_GATE=true
# Blocking mode: generate full answer, run deterministic + verify gates, and
# enforce/refuse in code before sending. Disables streaming. Default off.
SOP_BLOCKING=false
# Verify gate: structured post-check + one corrective regeneration (blocking only).
SOP_VERIFY_GATE=false
# Strict monitor (default on): aggressive monitor + harsh internal scold-correction
# (never leaked to the user) + concrete-citation enforcement + refuse-if-unfixable.
# Implies non-streaming. Set false for plain streaming.
SOP_STRICT_MONITOR=true

# --- Grok (xAI) search tool ---
# Lets the local model call a `grok_search` tool that borrows Grok's server-side
# X (Twitter) + web search and returns only Grok's synthesized answer.
# Get a key at https://console.x.ai. Leave empty to disable the feature.
XAI_API_KEY=
# Model with server-side search tools. Docs use grok-4.3; grok-build-0.1 is the
# fast agentic model. If a model rejects web_search/x_search, switch this.
GROK_MODEL=grok-build-0.1
# XAI_BASE_URL=https://api.x.ai/v1
