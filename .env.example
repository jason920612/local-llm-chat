# LM Studio / llama.cpp OpenAI-compatible endpoint
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio

# Chat (multimodal) model — load this in LM Studio first. Use the exact key
# from `lms ls` / LM Studio.
# Recommended: google/gemma-4-12b (best quality on ~8GB VRAM, vision-capable,
# non-Chinese). For low VRAM / faster: google/gemma-3-4b.
LLM_MODEL=google/gemma-4-12b

# Embedding model for RAG — load this in LM Studio as well.
# Recommended: nomic-embed-text-v1.5 (non-Chinese, 768-dim).
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# --- SOP control layer (enforced in CODE, not by the prompt) ---
# Intent gate: structured pre-check that can force a clarifying question and stop
# the turn before any answer is generated.
SOP_INTENT_GATE=true
# Blocking mode: generate full answer, run deterministic + verify gates, and
# enforce/refuse in code before sending. Disables streaming. Default on.
SOP_BLOCKING=true
# Verify gate: structured post-check + one corrective regeneration (blocking only).
SOP_VERIFY_GATE=false
# Stance gate: triggered LLM judge that blocks artificial balance, false
# equivalence, vague caveats, and unsupported uncertainty. Default on.
SOP_STANCE_GATE=true
# Strict monitor (default on): aggressive monitor + harsh internal scold-correction
# (never leaked to the user) + concrete-citation enforcement + refuse-if-unfixable.
# Implies non-streaming. Set false for plain streaming.
SOP_STRICT_MONITOR=true

# --- Local/host background jobs ---
# These apply to local background tools only. microVM run_code backgrounding keeps
# its separate one-background-run-per-conversation guard.
BACKGROUND_MAX_CONCURRENT_GLOBAL=8
BACKGROUND_MAX_CONCURRENT_PER_CONVERSATION=5

# --- Grok (xAI) search tool ---
# Lets the local model call a `grok_search` tool that borrows Grok's server-side
# X + web search and returns only Grok's synthesized answer.
# Get a key at https://console.x.ai. Leave empty to disable the feature.
XAI_API_KEY=
# Model with server-side search tools. Docs use grok-4.3; grok-build-0.1 is the
# fast agentic model. If a model rejects web_search/x_search, switch this.
GROK_MODEL=grok-build-0.1
# XAI_BASE_URL=https://api.x.ai/v1
# Max tool-call rounds per turn (observe→act loops). Higher lets the model run
# longer multi-step GUI / browsing tasks before the turn is forced to finish.
GROK_MAX_ROUNDS=48
# Grok Imagine media models. Video generation intentionally uses the 1.5
# image-to-video model; text-only video prompts first generate a base image.
XAI_IMAGE_MODEL=grok-imagine-image-quality
XAI_VIDEO_MODEL=grok-imagine-video-1.5
# Optional: request xAI priority scheduling for text/image/video/TTS/STT.
# Leave unset/default for normal cost. Set to priority only when latency matters.
XAI_SERVICE_TIER=default
# Web Search extras: lets Grok find image results and inspect images it finds.
XAI_WEB_SEARCH_IMAGE_SEARCH=true
XAI_WEB_SEARCH_IMAGE_UNDERSTANDING=true
# Streaming STT via local WebSocket proxy (/api/stt/stream) + xAI Smart Turn.
XAI_STT_STREAMING=true
XAI_STT_SMART_TURN=0.7
XAI_STT_SMART_TURN_TIMEOUT_MS=3000

# --- Code execution sandbox (Grok run_code tool) ---
# WARNING: with the default "local" driver this runs model-written bash/python on
# THIS machine with the server's permissions — workspace isolation + auto-cleanup,
# NOT a security boundary. Only enable if you trust the model. Off by default.
SANDBOX_ENABLED=false

# Execution backend:
#   local   — spawn python/bash on the host (fast, NOT isolated; default).
#   microvm — per-conversation Cloud Hypervisor microVM with its own Linux kernel,
#             run inside WSL2 (true isolation: own kernel, virtio-fs workspace,
#             NAT egress). Requires the one-time WSL2 host setup (see README).
SANDBOX_DRIVER=local

# --- microVM driver settings (only used when SANDBOX_DRIVER=microvm) ---
# WSL2 distro that hosts the hypervisor + per-conversation workspaces.
SANDBOX_WSL_DISTRO=Ubuntu
# Persistent per-conversation workspace root, inside WSL2.
SANDBOX_WSL_ROOT=/srv/llm-sandboxes
# Where the build artifacts (cloud-hypervisor, kernel, base rootfs, vm-run.sh) live.
SANDBOX_WSL_HOME=/home/jason/llm-sandbox
# Per-VM resources and global concurrency cap.
SANDBOX_VM_VCPUS=2
# RAM ceiling per VM (lazily allocated). Big = VM runs in memory + room for tmpfs /tmp.
SANDBOX_VM_MEM_MIB=8192
# Maximum number of conversation VMs alive at once. Each conversation uses at
# most one VM, and that VM may run many run_code/background jobs concurrently.
SANDBOX_VM_MAX_CONCURRENT=4
# Per-conversation VM session hard ceiling and idle shutdown.
SANDBOX_VM_SESSION_MAX_MS=21600000
SANDBOX_VM_IDLE_MS=1800000
# Per-conversation writable system disk (overlay upper + /tmp): apparent size in
# GiB. Thin/sparse — only real usage hits the host disk — and persistent, so the
# model's apt/system installs survive across runs.
SANDBOX_VM_SYSDISK_GIB=100
# VM computer-use is enabled by default for the microVM driver. The first
# computer_observe/action bootstraps Xvfb/openbox/Chromium/xdotool/scrot/wmctrl
# inside the VM system disk, then reuses them.
SANDBOX_VM_COMPUTER_USE=true
SANDBOX_VM_COMPUTER_AUTOINSTALL=true
# Global kill-switch for OCR. OCR itself is opt-in per call: the model sets
# ocr=true on computer_observe only when it needs on-screen text + clickable
# element coordinates. OCR uses PP-OCRv6 (medium) via PaddleOCR, run under a
# standalone CPython 3.12 worker baked into base.img (the VM's system Python 3.14
# has no PaddlePaddle wheel). You MUST prebake it with
# sandbox-host/build/stage3f-ocr.sh — OCR cannot be installed at runtime.
SANDBOX_VM_COMPUTER_OCR=true
SANDBOX_VM_SCREEN_WIDTH=1280
SANDBOX_VM_SCREEN_HEIGHT=720
# Optional for v2 browser computer-use: bake Playwright Chromium with
# sandbox-host/build/stage3e-browser.sh for fast first browser_open_url.
