    "mtls:p12": "node scripts/cloudflare-client-pem-to-p12.mjs",
    "tunnel:named": "powershell -ExecutionPolicy Bypass -File scripts/start-cloudflare-named-tunnel.ps1",
    "tunnel:quick": "powershell -ExecutionPolicy Bypass -File scripts/start-cloudflare-quick-tunnel.ps1",
    "lint": "next lint"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.3.3",
    "better-sqlite3": "^12.11.1",
