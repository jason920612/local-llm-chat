{
  "name": "local-llm-chat",
  "version": "0.1.0",
  "private": true,
  "description": "Local LLM web chat with multimodal (vision), RAG, and voice — powered by LM Studio / llama.cpp",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/next-with-xai-stt-ws.mjs",
    "start:next": "next start",
    "https:setup": "node scripts/setup-lan-https.mjs",
    "https:proxy": "node scripts/https-lan-proxy.mjs",
