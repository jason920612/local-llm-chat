    "@tailwindcss/postcss": "^4.0.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.13.2",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.18.1",
    "node-forge": "^1.4.0",
    "tailwindcss": "^4.0.3",
    "typescript": "^5.7.3"
