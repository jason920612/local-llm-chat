    "lucide-react": "^0.475.0",
    "mermaid": "^11.15.0",
    "nanoid": "^5.0.9",
    "next": "^15.1.6",
    "openai": "^4.83.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.0",
    "vega-lite": "^6.4.3",
    "ws": "^8.21.0",
    "zod": "^3.24.1"
